{
  "healthcheck": {
    "request": {
      "method": "GET",
      "url": "/api/health"
    },
    "response_200": {
      "status": "ok",
      "service": "dashboard-backend",
      "port": 3001,
      "offline_timeout_ms": 90000
    }
  },
  "cadastrar_equipamento": {
    "request": {
      "method": "POST",
      "url": "/api/equipamentos",
      "headers": {
        "Content-Type": "application/json"
      },
      "body": {
        "nome": "Monitor Multiparamétrico 101",
        "codigo": "MONITOR-101",
        "tipo": "Monitor Multiparamétrico",
        "marca": "Philips",
        "modelo": "IntelliVue MX550",
        "patrimonio": "PAT-000101",
        "setor": "Sala Vermelha",
        "descricao": "Monitor multiparamétrico para acompanhamento clínico"
      }
    },
    "response_201": {
      "message": "Equipamento cadastrado com sucesso.",
      "id": 2
    }
  },
  "telemetria_minima_esp32": {
    "request": {
      "method": "POST",
      "url": "/api/iot/eventos",
      "headers": {
        "Content-Type": "application/json"
      },
      "body": {
        "c": "MONITOR-101",
        "s": 1
      }
    },
    "response_201": {
      "message": "Evento recebido com sucesso.",
      "evento_id": 10,
      "equipamento": {
        "id": 2,
        "nome": "Monitor Multiparamétrico 101",
        "codigo": "MONITOR-101",
        "tipo": "Monitor Multiparamétrico",
        "marca": "Philips",
        "modelo": "IntelliVue MX550"
      }
    }
  }
}
